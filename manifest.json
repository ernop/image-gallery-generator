{
  "manifest_version": 3,
  "name": "4Chan Gallery Viewer WG",
  "short_name": "GalleryView",
  "version": "0.0.26",
  "description": "Adds gallery button to 4chan thread views with keyboard shortcuts for fast image browsing and saving.",
  "permissions": [
    "downloads",
    "storage",
    "scripting"
  ],
  "optional_permissions": [
    "<all_urls>"
  ],
  "host_permissions": [
    "https://code.jquery.com/*"
  ],
  "action": {
    "default_icon": "icon.png"
  },
  "content_scripts": [{
    "js": [
      "jquery.js",
      "util.js",
      "settingsModule.js",
      "labelsModule.js",
      "main.js"
    ],
    "css": ["styles.css"],
    "matches": [
      "*://boards.4chan.org/*",
      "*://boards.4channel.org/*"
    ]
  }],
  "options_ui": {
    "page": "options.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{2381ef0e-653b-4549-b953-27124405c12e}",
      "strict_min_version": "109.0"
    }
  }
}
